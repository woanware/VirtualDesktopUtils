<Window
  x:Class="VirtualDesktopUtils.WindowMain"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="VirtualDesktopUtils"
  Icon="Assets/VirtualDesktopUtils.ico"
  SizeToContent="WidthAndHeight"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterScreen"
  Background="#2C2C2C"
  Foreground="White"
>
  <Window.Resources>
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Background" Value="#2B6DEB" />
      <Setter Property="BorderBrush" Value="#2B6DEB" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Background="#2C2C2C" CornerRadius="14" Padding="2" Margin="0,0,6,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Settings" />

        <CheckBox
          x:Name="AutoRefreshCheckBox"
          Grid.Row="1"
          Margin="0,4,0,8"
          Content="Auto-refresh desktop state"
          FontSize="15"
          Foreground="White"
          Checked="AutoRefreshCheckBox_OnChecked"
          Unchecked="AutoRefreshCheckBox_OnUnchecked"
        />

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock
            VerticalAlignment="Center"
            FontSize="15"
            Foreground="White"
            Text="Refresh interval"
          />
          <ComboBox
            x:Name="RefreshIntervalComboBox"
            Width="140"
            Margin="10,0,0,0"
            FontSize="15"
            DisplayMemberPath="Label"
            SelectionChanged="RefreshIntervalComboBox_OnSelectionChanged"
          />
        </StackPanel>

        <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
          <CheckBox
            x:Name="StartWithWindowsCheckBox"
            Content="Start automatically with Windows"
            FontSize="15"
            Foreground="White"
            VerticalAlignment="Center"
            Checked="StartWithWindowsCheckBox_OnChecked"
            Unchecked="StartWithWindowsCheckBox_OnUnchecked"
          />
        </DockPanel>

        <DockPanel Grid.Row="4" Margin="0,10,0,0" LastChildFill="False">
          <CheckBox
            x:Name="GuidAutoUpdateCheckBox"
            Content="Auto-update COM GUID config on startup"
            FontSize="15"
            Foreground="White"
            VerticalAlignment="Center"
            Checked="GuidAutoUpdateCheckBox_OnChecked"
            Unchecked="GuidAutoUpdateCheckBox_OnUnchecked"
          />
          <Button
            x:Name="UpdateGuidConfigButton"
            Width="30"
            Height="30"
            Margin="12,0,0,0"
            Cursor="Hand"
            ToolTip="Sync GUID config from upstream now"
            Click="UpdateGuidConfigButton_OnClick"
          >
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="#2B6DEB" CornerRadius="4" Width="30" Height="30">
                  <TextBlock
                    Text="🔄"
                    FontSize="15"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#3A7DF5" />
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#1E5AC0" />
                  </Trigger>
                  <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </DockPanel>

        <StackPanel
          Grid.Row="5"
          Margin="0,10,0,0"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <TextBlock
            VerticalAlignment="Center"
            FontSize="15"
            Foreground="White"
            Text="Picker hotkey"
          />
          <TextBox
            x:Name="PickerHotkeyTextBox"
            Width="220"
            Margin="10,0,0,0"
            FontSize="15"
            IsReadOnly="True"
            Cursor="Hand"
            Background="#3A3A3A"
            Foreground="White"
            BorderBrush="#555"
            Padding="8,6"
            PreviewKeyDown="PickerHotkeyTextBox_PreviewKeyDown"
            GotFocus="HotkeyTextBox_GotFocus"
            LostFocus="HotkeyTextBox_LostFocus"
          />
          <TextBlock
            x:Name="PickerHotkeyStatusTextBlock"
            VerticalAlignment="Center"
            Margin="10,0,0,0"
            FontSize="14"
            Foreground="White"
            Text=""
          />
        </StackPanel>

        <StackPanel
          Grid.Row="6"
          Margin="0,10,0,0"
          Orientation="Horizontal"
          VerticalAlignment="Center"
        >
          <TextBlock
            VerticalAlignment="Center"
            FontSize="15"
            Foreground="White"
            Text="Direct move hotkey"
          />
          <TextBox
            x:Name="MoveHotkeyTextBox"
            Width="190"
            Margin="10,0,0,0"
            FontSize="15"
            IsReadOnly="True"
            Cursor="Hand"
            Background="#3A3A3A"
            Foreground="White"
            BorderBrush="#555"
            Padding="8,6"
            PreviewKeyDown="MoveHotkeyTextBox_PreviewKeyDown"
            GotFocus="HotkeyTextBox_GotFocus"
            LostFocus="HotkeyTextBox_LostFocus"
          />
          <TextBlock
            VerticalAlignment="Center"
            Margin="6,0,0,0"
            FontSize="13"
            Foreground="#80FFFFFF"
            Text="+1‒9"
          />
          <TextBlock
            x:Name="MoveHotkeyStatusTextBlock"
            VerticalAlignment="Center"
            Margin="10,0,0,0"
            FontSize="14"
            Foreground="White"
            Text=""
          />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
